@charset "utf-8";

* { box-sizing: border-box; margin: 0px; padding: 0px; }

body { font-family: system-ui, -apple-system, "Segoe UI", Roboto, Arial, sans-serif; background: rgb(248, 250, 252); color: rgb(30, 41, 59); line-height: 1.7; }

.container { max-width: 1100px; margin: auto; padding: 20px; }

.site-header { background: rgb(255, 255, 255); border-bottom: 1px solid rgb(229, 231, 235); text-align: center; padding: 20px; }

.site-header h1 { font-size: 2.3rem; margin-bottom: 10px; }

.subtitle { color: rgb(100, 116, 139); }

.languages { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 22px; }

.language-card { background: rgb(255, 255, 255); border: 1px solid rgb(226, 232, 240); border-radius: 10px; padding: 20px; }

.site-footer { text-align: center; padding: 30px 20px; margin-top: 60px; border-top: 1px solid rgb(229, 231, 235); color: rgb(100, 116, 139); }

.nav-bar { display: flex; justify-content: space-between; align-items: center; padding: 10px 20px; max-width: 1100px; margin: auto; }

.logo { font-size: 20px; font-weight: bold; color: rgb(29, 78, 216); }

.nav-menu { display: flex; gap: 20px; }

.nav-menu a { text-decoration: none; color: rgb(30, 41, 59); font-weight: 500; }

.nav-menu a:hover { color: rgb(29, 78, 216); }

.menu-toggle { display: none; font-size: 24px; cursor: pointer; }

.footer-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 20px; text-align: left; }

.footer-grid h4 { margin-bottom: 10px; color: rgb(30, 41, 59); }

.footer-grid a { display: block; text-decoration: none; color: rgb(100, 116, 139); margin-bottom: 6px; }

.footer-grid a:hover { color: rgb(29, 78, 216); }

@media (max-width: 768px) {
  .nav-menu { display: none; flex-direction: column; background: rgb(255, 255, 255); position: absolute; right: 10px; top: 60px; border: 1px solid rgb(229, 231, 235); padding: 15px; }
  .nav-menu.active { display: flex; }
  .menu-toggle { display: block; }
}
